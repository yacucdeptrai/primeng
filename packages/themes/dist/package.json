{
    "name": "@primeng/themes",
    "version": "21.1.3",
    "author": "PrimeTek Informatics",
    "description": "",
    "homepage": "https://primeng.org/",
    "license": "SEE LICENSE IN LICENSE.md",
    "repository": {
        "type": "git",
        "url": "https://github.com/primefaces/primeng.git",
        "directory": "packages/themes"
    },
    "bugs": {
        "url": "https://github.com/primefaces/primeng/issues"
    },
    "main": "./src/index.ts",
    "module": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./*": "./src/presets/*/index.ts"
    },
    "publishConfig": {
        "main": "./index.mjs",
        "module": "./index.mjs",
        "types": "./index.d.mts",
        "exports": {
            ".": {
                "types": "./index.d.mts",
                "import": "./index.mjs"
            },
            "./*": {
                "types": "./*/index.d.ts",
                "import": "./*/index.mjs"
            }
        },
        "access": "public"
    },
    "dependencies": {
        "@primeuix/styled": "catalog:"
    }
}
